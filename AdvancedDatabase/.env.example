POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_META_DB=rag_meta
POSTGRES_PGVECTOR_DB=rag_vector
POSTGRES_META_PORT=5433
POSTGRES_PGVECTOR_PORT=5434
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

POSTGRES_META_DSN=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_META_PORT}/${POSTGRES_META_DB}
POSTGRES_PGVECTOR_DSN=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PGVECTOR_PORT}/${POSTGRES_PGVECTOR_DB}
QDRANT_URL=http://localhost:${QDRANT_HTTP_PORT}
QDRANT_COLLECTION=documents
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

EXPERIMENT_DOCUMENTS=1000
EXPERIMENT_REPEATS=30
EXPERIMENT_WARMUP=1
